{
    "swagger": "2.0",
    "info": {
        "description": "API для сервиса  Pioneer.",
        "title": "Pioneer API",
        "contact": {}
    },
    "basePath": "/",
    "paths": {
        "/branch": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Получить филиал для определённого города с определённым сервисом",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "branch"
                ],
                "summary": "Получить филиал для заказа",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Город",
                        "name": "city",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "ID Сервиса",
                        "name": "service",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/branch.BrancByCityServ"
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/branch/freetime": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Возвращает доступное время записи в определёный филиал с учётом общей длительности услуги на неделю",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "branch"
                ],
                "summary": "Получить доступное время для записи",
                "parameters": [
                    {
                        "type": "string",
                        "description": "ID Филиала",
                        "name": "branch_id",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Дата начала недели формат yyyy-mm-dd",
                        "name": "date",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Общая длительность услуги в минутах",
                        "name": "duration",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/order.DailySlots"
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/branch/service/details/{id_branchserv}": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Получение состава услуги по id branchserv для авторизованных пользователей",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "branch"
                ],
                "summary": "Получить состав услуги",
                "parameters": [
                    {
                        "type": "string",
                        "description": "branchserv ID",
                        "name": "id_branchserv",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/branch.ServiceDetails"
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/client/city": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Возвращает город авторизованного клиента",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "client"
                ],
                "summary": "Получить город клиента",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/client.GetCityResponse"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            },
            "put": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Обновляет город клиента, если тот есть в списке городов (в любом регистре)",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "client"
                ],
                "summary": "Обновить город клиента",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/client.UpdateCityRequest"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/client/orders": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Возвращает все заказы, принадлежащие авторизованному клиенту.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "clients"
                ],
                "summary": "Получить заказы клиента",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/order.ClientOrderResponse"
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/order": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Создаёт новый заказ для авторизованного клиента на доступное время.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "order"
                ],
                "summary": "Создать заказ",
                "parameters": [
                    {
                        "description": "Данные для создания заказа",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/order.CreateOrderRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/order.Order"
                        }
                    },
                    "400": {
                        "description": "Invalid request body or business logic error",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/services": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Возвращает список общих услуг и их ID",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "services"
                ],
                "summary": "Получить список услуг",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/service.ServiceResponse"
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "branch.BrancByCityServ": {
            "type": "object",
            "properties": {
                "address": {
                    "type": "string",
                    "example": "ул. Тверская, д. 1"
                },
                "id_branch": {
                    "type": "string",
                    "format": "uuid",
                    "example": "0bb7a20d-4ffc-46cd-b5e5-a549a179ce2a"
                },
                "id_branchserv": {
                    "type": "string",
                    "format": "uuid",
                    "example": "0bb7a20d-4ffc-46cd-b5e5-a549a179ce2a"
                },
                "org_short_name": {
                    "type": "string",
                    "example": "ООО Ромашка"
                }
            }
        },
        "branch.ServiceDetails": {
            "type": "object",
            "properties": {
                "detail": {
                    "type": "string",
                    "example": "Мойка колёс"
                },
                "duration_min": {
                    "type": "integer",
                    "example": 35
                }
            }
        },
        "client.GetCityResponse": {
            "type": "object",
            "properties": {
                "city": {
                    "type": "string",
                    "example": "Москва"
                }
            }
        },
        "client.UpdateCityRequest": {
            "type": "object",
            "properties": {
                "city": {
                    "type": "string",
                    "example": "мОсква"
                }
            }
        },
        "order.ClientOrderResponse": {
            "type": "object",
            "properties": {
                "address": {
                    "type": "string",
                    "example": "ул. Тверская, д. 1"
                },
                "city": {
                    "type": "string",
                    "example": "Москва"
                },
                "end_moment": {
                    "type": "string",
                    "format": "yyyy-mm-ddThh:mm:ss+(Z)hh:mm",
                    "example": "2026-03-16T11:05:00+04:00"
                },
                "name_company": {
                    "type": "string",
                    "example": "ООО \"Ромашка\""
                },
                "order_details": {
                    "type": "object"
                },
                "order_id": {
                    "type": "string",
                    "example": "83817fd0-ffd0-478b-b1ae-b082e8581830"
                },
                "service": {
                    "type": "string",
                    "example": "Шиномонтаж"
                },
                "start_moment": {
                    "type": "string",
                    "format": "yyyy-mm-ddThh:mm:ss+(Z)hh:mm",
                    "example": "2026-03-16T09:30:00+04:00"
                }
            }
        },
        "order.CreateOrderRequest": {
            "type": "object",
            "properties": {
                "order_details": {
                    "type": "object"
                },
                "service_by_branch": {
                    "type": "string",
                    "format": "uuid",
                    "example": "89d74b8a-8cee-44fa-96ea-6aec1e8ad66b"
                },
                "start_moment": {
                    "type": "string",
                    "format": "yyyy-mm-ddThh-mm-ss+hh:mm",
                    "example": "2026-03-16T11:20:00+04:00"
                }
            }
        },
        "order.DailySlots": {
            "type": "object",
            "properties": {
                "date": {
                    "type": "string",
                    "format": "yyyy-mm-ddT00:00:00Z",
                    "example": "2026-03-16T00:00:00Z"
                },
                "intervals": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "example": [
                        "[2026-03-17T10:35:00+04:00",
                        " 2026-03-17T10:50:00+04:00",
                        " 2026-03-17T11:05:00+04:00]"
                    ]
                }
            }
        },
        "order.Order": {
            "type": "object",
            "properties": {
                "end_moment": {
                    "type": "string",
                    "example": "2026-04-16T05:20:00Z"
                },
                "id": {
                    "type": "string",
                    "example": "e77fd339-9478-4375-82c1-215936a68b8a"
                },
                "order_details": {
                    "type": "object"
                },
                "service_by_branch": {
                    "type": "string",
                    "example": "917e77fa-1672-4dfb-8507-d5755b31ebb3"
                },
                "start_moment": {
                    "type": "string",
                    "example": "2026-04-16T05:00:00Z"
                },
                "users": {
                    "type": "string",
                    "example": "ex@mail.ru"
                }
            }
        },
        "service.ServiceResponse": {
            "type": "object",
            "properties": {
                "id": {
                    "type": "string",
                    "format": "uuid",
                    "example": "83817fd0-ffd0-478b-b1ae-b082e8581830"
                },
                "name": {
                    "type": "string",
                    "example": "Aвтомойка"
                }
            }
        }
    },
    "securityDefinitions": {
        "BearerAuth": {
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}